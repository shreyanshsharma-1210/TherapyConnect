# TherapyConnect — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to source control.

# ─── Supabase ────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Razorpay ────────────────────────────────────────────
# Payment Mode: demo (for QA/testing) or razorpay (production)
VITE_PAYMENT_MODE=demo
# Frontend publishable key only (secret key goes to Supabase secrets)
VITE_RAZORPAY_KEY_ID=rzp_test_or_live_key

# ─── Analytics ───────────────────────────────────────────
# PostHog (https://posthog.com — free tier available)
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Error Monitoring ────────────────────────────────────
# Sentry (https://sentry.io — free tier available)
VITE_SENTRY_DSN=https://xxxx@oxxxxxx.ingest.sentry.io/xxxxxxx

# ─── App Config ──────────────────────────────────────────
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# ─── Supabase Secrets (Set in Supabase Dashboard ONLY) ───
# These are NEVER put in .env — server-side only
# RAZORPAY_KEY_SECRET=...
# RESEND_API_KEY=...
# SENDER_EMAIL=...
# RAZORPAY_WEBHOOK_SECRET=...
